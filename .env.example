# App
DATABASE_URL=file:./data/aicomic.db
UPLOAD_DIR=./uploads

# 本地代理（可选）
# 填写后，Node.js 服务端所有 fetch 请求（含 @google/genai SDK）自动走此代理，
# 解决 googleapis.com 等境外 API 在国内服务端无法直连的问题。
# 须先安装依赖：pnpm add undici
#
# pnpm dev 本地开发（代理跑在本机）：
# HTTPS_PROXY=http://127.0.0.1:7897
#
# Docker 启动（代理跑在宿主机，容器需用 host.docker.internal）：
# HTTPS_PROXY=http://host.docker.internal:7897
#
# 端口换成你的 VPN 客户端（Clash Verge / ClashX 等）实际暴露的 HTTP 代理端口。

# 设为 1 时关闭：删 cookie 后把「单用户」库内项目自动归到当前浏览器 ID（本地无登录模式）
# AI_COMIC_DISABLE_LOCAL_RECLAIM=1

# 保存 API 密钥后：防抖生成完整 SQLite 快照到 data/backups/（与 DATABASE_URL 同目录）。设为 1 可关闭。
# AI_COMIC_DISABLE_DB_BACKUP=1

# 可选：设置后每次写入密钥会额外把 provider_secrets 加密写入 data/secrets-vault.enc.json（≥8 字符口令）
# AI_COMIC_SECRETS_VAULT_KEY=

# Docker build (optional): Alpine apk mirror host.
# Used by `docker compose build` only, ignored by `pnpm dev`.
# Keep default official mirror unless your network is unstable.
ALPINE_MIRROR=https://dl-cdn.alpinelinux.org
